@model LeaseListing
@{
    ViewData["Title"] = "Delete Lease";
}

<div class="market-form-page">
    <h1 class="market-form-title text-danger">Delete Listing</h1>
    <p class="market-form-subtitle">Are you sure you want to permanently remove this lease?</p>

    <div class="market-form-shell">
        <div class="market-form">

            <div class="form-group" style="margin-top:20px;">
                <div style="border:1.5px solid #dc2626; border-radius:16px; padding:18px;">
                    <h3 style="font-weight:900; margin-bottom:10px;">@Model.Title</h3>
                    <p><strong>Price:</strong> $@Model.Price</p>
                    <p style="color:#64748b; font-size:14px;">
                        Created on: @Model.CreatedAt.ToShortDateString()
                    </p>
                </div>
            </div>

            <form action="/api/LeaseAPI/delete/@Model.Id" method="post">

                <div style="margin-top:18px; padding:14px; border-radius:14px; background:rgba(245,158,11,0.18); font-weight:800; color:#7c5600;">
                    This action cannot be undone.
                </div>

                <div class="market-form-actions">
                    <button type="submit" class="market-btn-primary" style="background:#dc2626; border-color:#dc2626;">
                        Permanently Delete
                    </button>

                    <a href="/Listings/Leases" class="market-btn-link">
                        Cancel
                    </a>
                </div>
            </form>

        </div>
    </div>
</div>