@model ETSU_Marketplace.ViewModels.HomeIndexViewModel
@{
    ViewData["Title"] = "Leases";
}

<section class="listings-wrap">
    <a class="back-link" asp-controller="Home" asp-action="Index">← Back to Home</a>

    <h1 class="page-title">Lease Takeovers</h1>
    <h3 class="section-subtitle">Latest Listings</h3>

    @if (Model?.LatestLeaseListings != null && Model.LatestLeaseListings.Any())
    {
        <div class="latest-grid">
            @foreach (var card in Model.LatestLeaseListings)
            {
                <a class="latest-card" href="@card.DetailsUrl" data-title="@card.Title" data-description="@card.ShortDescription">
                    <div class="latest-img">
                        <img src="@(card.ImageUrl)"
                            alt="@card.Title" />
                    </div>

                    <div class="latest-price">$@card.Price.ToString("0.00")</div>
                    <div class="latest-name">@card.Title</div>
                </a>
            }
        </div>
    }
    else
    {
        <div class="empty-state">No lease takeover listings yet.</div>
    }
</section>