@model LeaseListing
@{
    ViewData["Title"] = "Create Lease Listing";
}

<div class="market-form-page">
    <h1 class="market-form-title">Create</h1>
    <div class="market-form-subtitle">LeaseListing</div>

    <div class="market-form-shell">
        <form class="market-form" asp-action="Post" asp-controller="LeaseAPI">
            <div asp-validation-summary="ModelOnly" class="text-danger"></div>

            <div class="form-group">
                <label asp-for="Address" class="control-label"></label>
                <input asp-for="Address" class="form-control" />
                <span asp-validation-for="Address" class="text-danger"></span>
            </div>

            <div class="form-group">
                <label asp-for="LeaseStart" class="control-label"></label>
                <input asp-for="LeaseStart" class="form-control" type="date" />
                <span asp-validation-for="LeaseStart" class="text-danger"></span>
            </div>

            <div class="form-group">
                <label asp-for="LeaseEnd" class="control-label"></label>
                <input asp-for="LeaseEnd" class="form-control" type="date" />
                <span asp-validation-for="LeaseEnd" class="text-danger"></span>
            </div>

            <div class="form-check">
                <input class="form-check-input" asp-for="UtilitiesIncluded" />
                <label class="form-check-label" asp-for="UtilitiesIncluded">
                    @Html.DisplayNameFor(m => m.UtilitiesIncluded)
                </label>
            </div>

            <div class="form-group">
                <label asp-for="Title" class="control-label"></label>
                <input asp-for="Title" class="form-control" />
                <span asp-validation-for="Title" class="text-danger"></span>
            </div>

            <div class="form-group">
                <label asp-for="Description" class="control-label"></label>
                <textarea asp-for="Description" class="form-control"></textarea>
                <span asp-validation-for="Description" class="text-danger"></span>
            </div>

            <div class="form-group">
                <label asp-for="Price" class="control-label"></label>
                <input asp-for="Price" class="form-control" type="number" step="0.01" />
                <span asp-validation-for="Price" class="text-danger"></span>
            </div>

            <div class="market-form-actions">
                <button type="submit" class="market-btn-primary">Create</button>
                <a asp-action="Index" class="market-btn-link">Back to List</a>
            </div>
        </form>
    </div>
</div>